{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/service-worker.js",
      "dest": "service-worker.js"
    },
    {
      "src": "/manifest.json",
      "dest": "manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
