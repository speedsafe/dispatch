# Google Calendar ICS Feed URL
# Get this from Google Calendar Settings → Share → Copy ICS feed URL
CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/c_xxxxx%40group.calendar.google.com/private-xxxxx/basic.ics

# Mapbox for route optimization (optional)
MAPBOX_TOKEN=your_mapbox_token_here

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5000
